{
  "name": "lumina-blog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky",
    "commit": "git add . && cz"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.22.0",
    "@tiptap/extension-highlight": "^3.22.0",
    "@tiptap/extension-horizontal-rule": "^3.22.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.0",
    "@tiptap/extension-task-list": "^3.22.0",
    "@tiptap/extension-text-align": "^3.22.0",
    "@tiptap/extension-text-style": "^3.22.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "pinia": "^3.0.0",
    "tiptap-markdown-3": "^0.8.12",
    "vue": "^3.5.30",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@tiptap/pm": "^3.22.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.0",
    "eslint-plugin-vue": "^9.30.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-cdn-import": "^1.0.1",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.28.1",
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  }
}
