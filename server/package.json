    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/md5-file": "^4.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  },
  "packageManager": "pnpm@10.28.1"
